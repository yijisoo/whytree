#!/usr/bin/env bash
set -e

echo ""
echo "  🌳 Setting up Why Tree"
echo ""

# Check Node.js
if ! command -v node &>/dev/null; then
  echo "  Error: Node.js is required. Install from https://nodejs.org"
  exit 1
fi

# Get the directory where this script lives
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

# Save current version
git rev-parse --short HEAD > "$SCRIPT_DIR/.version" 2>/dev/null || true

# Install dependencies
echo "  Installing dependencies..."
npm install --silent 2>/dev/null

# Link CLI globally
echo "  Linking whytree command..."
npm link --silent 2>/dev/null || {
  echo "  Note: 'npm link' failed (may need sudo). You can still use: node bin/whytree.js"
}

# Install Claude Code skill — copy to global skills dir if installed elsewhere
GLOBAL_SKILL_DIR="$HOME/.claude/skills/whytree"
if [ "$SCRIPT_DIR" != "$GLOBAL_SKILL_DIR" ]; then
  mkdir -p "$GLOBAL_SKILL_DIR"
  cp "$SCRIPT_DIR/.claude/skills/whytree/SKILL.md" "$GLOBAL_SKILL_DIR/SKILL.md"
  echo "  Installed /whytree skill to $GLOBAL_SKILL_DIR"
else
  echo "  Skill already at $GLOBAL_SKILL_DIR"
fi

# Install /whytree-feedback skill
FEEDBACK_SKILL_DIR="$HOME/.claude/skills/whytree-feedback"
if [ -d "$SCRIPT_DIR/.claude/skills/whytree-feedback" ]; then
  mkdir -p "$FEEDBACK_SKILL_DIR"
  cp "$SCRIPT_DIR/.claude/skills/whytree-feedback/SKILL.md" "$FEEDBACK_SKILL_DIR/SKILL.md"
  echo "  Installed /whytree-feedback skill to $FEEDBACK_SKILL_DIR"
fi

# Add whytree permission to global Claude Code settings
GLOBAL_SETTINGS="$HOME/.claude/settings.json"
PERM="Bash(whytree:*)"
if [ -f "$GLOBAL_SETTINGS" ]; then
  if ! grep -q "whytree" "$GLOBAL_SETTINGS" 2>/dev/null; then
    node -e "
      const fs = require('fs');
      const s = JSON.parse(fs.readFileSync('$GLOBAL_SETTINGS', 'utf-8'));
      if (!s.permissions) s.permissions = {};
      if (!s.permissions.allow) s.permissions.allow = [];
      if (!s.permissions.allow.includes('$PERM')) s.permissions.allow.push('$PERM');
      fs.writeFileSync('$GLOBAL_SETTINGS', JSON.stringify(s, null, 2) + '\n', 'utf-8');
    " && echo "  Added whytree permission to $GLOBAL_SETTINGS"
  fi
else
  echo '{
  "permissions": {
    "allow": [
      "Bash(whytree:*)"
    ]
  }
}' > "$GLOBAL_SETTINGS"
  echo "  Created $GLOBAL_SETTINGS with whytree permission"
fi

echo ""
echo "  Done! You can now:"
echo "    - Run 'whytree show' in your terminal"
echo "    - Type /whytree in Claude Code to start a guided session"
echo ""
